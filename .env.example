# Spotify Configuration
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cookie signing secret for the httpOnly spotify_token
SPOTIFY_TOKEN_COOKIE_SECRET=your_strong_random_secret

# Navidrome Configuration (optional - can configure via UI)
# NAVIDROME_URL=http://localhost:4533
# NAVIDROME_USERNAME=
# NAVIDROME_PASSWORD=

# Lidarr proxy (optional)
# Enable when Lidarr is behind Cloudflare Access/CORS restrictions
NEXT_PUBLIC_LIDARR_PROXY=false
LIDARR_INTERNAL_URL=http://lidarr
